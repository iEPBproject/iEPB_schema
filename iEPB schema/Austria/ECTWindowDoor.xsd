									<!--      <xs:element name="OtherTransparentPart" type="xs:boolean"/>-->
									<xs:element name="OtherTransparentPartHorizontalOrSloped" type="xs:boolean"/>
									<xs:element name="OtherTransparentPartVertical" type="xs:boolean"/>
									<!-- KST 27.01.2015 Renaming OtherTransparentPart END -->
									<xs:element name="RollDoorOrSectionalDoor" type="xs:boolean"/>
									<xs:element name="Materials">
										<xs:complexType>
											<xs:sequence>
												<xs:element name="Item" type="ECTWindowDoorAddonsBodyMaterial" minOccurs="0" maxOccurs="unbounded"/>
											</xs:sequence>
										</xs:complexType>
									</xs:element>

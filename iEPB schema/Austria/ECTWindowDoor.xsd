									<xs:element name="ThermalBridge_FreeInput" type="xs:boolean"/>
									<xs:element name="ThermalBridge_Description" type="xs:string"/>
									<xs:element name="u_Info" type="xs:string"/>
									<xs:element name="g" type="xs:float"/>

<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
	<xs:simpleType name="ENUMWindowDoorRenovationType">
		<xs:restriction base="xs:string">
			<xs:enumeration value="none"/>
			<xs:enumeration value="onlyInnerFillArea"/>
			<xs:enumeration value="complete"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:simpleType name="ENUMWindowDoorType">
		<xs:restriction base="xs:string">
			<xs:enumeration value="EXTERNALWINDOW"/>
			<xs:enumeration value="EXTERNALDOOR"/>
			<xs:enumeration value="INTERNALWINDOW"/>
			<xs:enumeration value="INTERNALDOOR"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:complexType name="ECTWindowDoorAddonsBodyMaterial">
		<xs:sequence>
			<xs:element name="Thickness" type="xs:float"/>
			<xs:element name="Polygon" type="ECTPolygon"/>
			<xs:element name="GenericParameters" minOccurs="0">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="Item" type="ECTGenericParameter" minOccurs="0" maxOccurs="unbounded"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
		<xs:attribute name="MaterialID"/>
	</xs:complexType>
	<xs:complexType name="ECTWindowDoor">
		<xs:annotation>
			<xs:documentation>Comment describing your root element</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="WindowDoorType" type="ENUMWindowDoorType"/>
			<xs:element name="Name" type="xs:string"/>
			<xs:element name="Info" type="xs:string"/>
			<xs:element name="DateChanged" type="xs:dateTime"/>
			<xs:element name="DateCreated" type="xs:dateTime"/>
			<xs:element name="Addons">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="Body">
							<xs:complexType>
								<xs:sequence>
									<xs:element name="InputType" type="ENUMInputType"/>
									<xs:element name="IsReferenceWindow" type="xs:boolean"/>
									<xs:element name="Eingabetyp_gWert" type="ENUMInputType"/>
									<xs:element name="Width" type="xs:float"/>
									<xs:element name="Height" type="xs:float"/>
									<xs:element name="GlasThickness" type="xs:float"/>
									<xs:element name="FrameThickness" type="xs:float"/>
									<xs:element name="FrameWidth" type="xs:float"/>
									<xs:element name="SillWidth" type="xs:float"/>
									<xs:element name="LintelWidth" type="xs:float"/>
									<xs:element name="WindowbarThickness" type="xs:float"/>
									<xs:element name="VerticalWindowbarCount" type="xs:float"/>
									<xs:element name="VerticalWindowbarWidth" type="xs:float"/>
									<xs:element name="HorizontalWindowbarCount" type="xs:float"/>
									<xs:element name="HorizontalWindowbarWidth" type="xs:float"/>
									<xs:element name="Glasratio" type="xs:float"/>
									<xs:element name="Glasperimeter_FreeInput_Checked" type="xs:boolean"/>

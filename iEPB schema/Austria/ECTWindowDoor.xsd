									<!--<xs:element name="u_1_23_x_1_48" type="xs:float"/> -->
									<xs:element name="u_ReferenceSize" type="xs:float"/>
									<!--KST 27.01.2014 renamed END -->
								</xs:sequence>
								<xs:attribute name="ThermalBridge_ID"/>
							</xs:complexType>
						</xs:element>
						<xs:element name="Acustic">
							<xs:complexType>
								<xs:sequence>
									<xs:element name="R" type="xs:float"/>
									<xs:element name="R_Info" type="xs:string"/>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
						<xs:element name="WindowDoorRenovationType" type="ENUMWindowDoorRenovationType"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="AutoGenerateName" type="xs:boolean"/>
			<xs:element name="GenericParameters">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="Item" type="ECTGenericParameter" minOccurs="0" maxOccurs="unbounded"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:sequence>
		<xs:attribute name="ID"/>
		<xs:attribute name=" ConstructionGroupID"/>
	</xs:complexType>
	<xs:element name="ECTWindowDoors">
		<xs:complexType>
			<xs:sequence>
				<xs:element name="Item" type="ECTWindowDoor" minOccurs="0" maxOccurs="unbounded"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
</xs:schema>

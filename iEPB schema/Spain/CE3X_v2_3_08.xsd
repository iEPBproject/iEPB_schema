	<xs:element name="HydronicLoopEquipment">
		<xs:complexType>
			<xs:sequence>
				<!-- Always -->
				<xs:element ref="Zone"/>
				<xs:choice minOccurs="0">
					<xs:sequence>
						<!-- Optional coverages -->
						<xs:element ref="HeatingCoverage" minOccurs="0"/>
						<xs:element ref="CoolingCoverage" minOccurs="0"/>
						<xs:element ref="DHWCoverage" minOccurs="0"/>
						<!-- Generator -->
						<xs:element ref="GeneratorType" minOccurs="0"/>
						<!-- ================= SECTIONS ================= -->
						<!-- BOILER or JOULE-->
						<xs:choice minOccurs="0">
							<xs:sequence>
								<xs:element ref="CombustionLoadFactor"/>
								<xs:element ref="CombustionEfficiency"/>
								<xs:element ref="InsulationBoiler" minOccurs="0"/>
							</xs:sequence>
							<xs:sequence>
								<xs:element ref="NominalEfficiency"/>
							</xs:sequence>
						</xs:choice>
						<!-- CHILLER / HP -->
						<xs:choice minOccurs="0">
							<xs:element ref="AgeOfHeatPump"/>
							<xs:sequence>
								<xs:element ref="refrigerationMachineAntiquity"/>
								<xs:element ref="HeatPumpType"/>
							</xs:sequence>
						</xs:choice>
						<xs:element ref="MultipleGeneratorsExistElement">
							<xs:sequence minOccurs="0">
								<xs:element ref="FractionPowerSupplied"/>
								<xs:element ref="FractionPowerInput"/>
							</xs:sequence>
						</xs:element>
						<xs:element ref="NominalEfficiencyCal" minOccurs="0"/>
						<xs:element ref="NominalEfficiencyRef" minOccurs="0"/>
						<xs:element ref="NominalEfficiencyACS" minOccurs="0"/>
						<xs:element ref="BoilerInsulationLevel" minOccurs="0"/>					
						<!-- DHW -->
						<xs:element ref="DHWTankPresent" minOccurs="0"/>
						<xs:sequence>	
							<xs:element ref="DHWUA" minOccurs="0"/>
							<xs:element ref="UACalculationType" minOccurs="0"/>
							<xs:sequence>
								<xs:element ref="HighTemperature" minOccurs="0"/>
								<xs:element ref="LowerTemperature" minOccurs="0"/>
								<xs:sequence>
									<xs:element ref="TankVolume" minOccurs="0"/>
									<xs:element ref="Multiplier" minOccurs="0"/>
									<xs:sequence>
										<xs:element ref="InsulationType" minOccurs="0"/>
										<xs:element ref="Thickness" minOccurs="0"/>
									</xs:sequence>
								</xs:sequence>
							</xs:sequence>	
						</xs:sequence>
					</xs:sequence>
					<xs:sequence>
						<!-- PUMPS -->
						<xs:element ref="Name" minOccurs="0"/>
						<xs:element ref="TypeOfPump" minOccurs="0"/>
						<xs:element ref="Service" minOccurs="0"/>
						<xs:element ref="Consumption" minOccurs="0"/>

						<xs:sequence minOccurs="0">
							<xs:element ref="NumberOfHoursWithDemand"/>
							<xs:element ref="WorksWhenNoDemand" minOccurs="0"/>
							<xs:sequence minOccurs="0">
								<xs:element ref="HeatingSeasonDuration"/>
								<xs:element ref="CoolingSeasonDuration"/>
								<xs:element ref="FractionPowerWhenNoDemand"/>
							</xs:sequence>
						</xs:sequence>
						<!-- COOLING TOWER -->
						<xs:element ref="TypeOfCoolingTower" minOccurs="0"/>
						<xs:choice minOccurs="0">
							<xs:element ref="ComsumptionCurveDefinition"/>
							<xs:element ref="StepPowerFractionDefinition"/>
						</xs:choice>
					</xs:sequence>				
				</xs:choice>
			</xs:sequence>
			<xs:attribute name="calculationType" use="required">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Conocido (Ensayado/justificado)"/>
						<xs:enumeration value="Estimado según Instalación"/>
						<xs:enumeration value="Estimado"/>
						<xs:enumeration value="Estimado por curva"/>
						<xs:enumeration value="Estimado por escalones"/><!-- El calculationType debería ser un enum? o únicamente un string? -->
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
			<xs:attribute name="serviceType" use="optional">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Equipo ACS"/>
						<xs:enumeration value="Equipo sólo calefacción"/>
						<xs:enumeration value="Equipo sólo refrigeración"/>
						<xs:enumeration value="Equipo mixto de calefacción y refrigeración"/>
						<xs:enumeration value="Equipo mixto de calefacción y ACS"/>
						<xs:enumeration value="Equipo mixto de calefacción, refrigeración y ACS"/>						
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
			<xs:attribute name="id" type="xs:ID" use="required"/>
			<xs:attribute name="equipmentType" type="hydronicEquipTypeEnum" use="required"/>
		</xs:complexType>
	</xs:element>	

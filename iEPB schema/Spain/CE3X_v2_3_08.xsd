<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
            targetNamespace="http://www.efinovatic.es/ce3x"
            xmlns="http://www.efinovatic.es/ce3x"
            elementFormDefault="qualified">

  <!-- =========================
       ELEMENTS
       ========================= -->

	<xs:element name="A" type="dectype2digits"/>	
	<xs:element name="B" type="dectype2digits"/>	
	<xs:element name="C" type="dectype2digits"/>	
	<xs:element name="D" type="dectype2digits"/>	
	<xs:element name="E" type="dectype2digits"/>	
	<xs:element name="F" type="dectype2digits"/>	
	<xs:element name="Absortance">
	<xs:complexType>
	  <xs:simpleContent>
		<xs:extension base="xs:string">
		  <xs:attribute name="colorType" use="required">
			<xs:simpleType>
			  <xs:restriction base="xs:string">
				<xs:enumeration value="blanco" />
				<xs:enumeration value="amarillo" />
				<xs:enumeration value="beige" />
				<xs:enumeration value="marron" />
				<xs:enumeration value="rojo" />
				<xs:enumeration value="verde" />
				<xs:enumeration value="azul" />
				<xs:enumeration value="gris" />
				<xs:enumeration value="negro" />
			  </xs:restriction>
			</xs:simpleType>
		  </xs:attribute>
		</xs:extension>
	  </xs:simpleContent>
	</xs:complexType>
	</xs:element>	
	<xs:element name="Acimut1">
		<xs:simpleType>
			<xs:restriction base="xs:double">
				<xs:minInclusive value="-180"/>
				<xs:maxInclusive value="180"/>				
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="Acimut2">
		<xs:simpleType>
			<xs:restriction base="xs:double">
				<xs:minInclusive value="-180"/>
				<xs:maxInclusive value="180"/>						
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="Acimut3">
		<xs:simpleType>
			<xs:restriction base="xs:double">
				<xs:minInclusive value="-180"/>
				<xs:maxInclusive value="180"/>						
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="Acimut4">
		<xs:simpleType>
			<xs:restriction base="xs:double">
				<xs:minInclusive value="-180"/>
				<xs:maxInclusive value="180"/>						
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="Activity">
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="Administrativo en general"/>
				<xs:enumeration value="Pabellones de exposición o ferias"/>
				<xs:enumeration value="Salas de diagnóstico"/>
				<xs:enumeration value="Aulas y laboratorios"/>
				<xs:enumeration value="Habitaciones de hospital"/>
				<xs:enumeration value="Zonas comunes"/>
				<xs:enumeration value="Almacenes, archivos, salas técnicas y cocinas"/>
				<xs:enumeration value="Espacios deportivos"/>
				<xs:enumeration value="Estaciones de transporte"/>
				<xs:enumeration value="Supermercados, hipermercados y grandes almacenes"/>
				<xs:enumeration value="Bibliotecas, museos y galerías de arte"/>
				<xs:enumeration value="Zonas comunes en edificios residenciales"/>
				<xs:enumeration value="Centros comerciales (excluidas tiendas)"/>
				<xs:enumeration value="Hostelería y restauración"/>
				<xs:enumeration value="Religioso en general"/>
				<xs:enumeration value="Auditorios, salas de actos, usos múltiples, convenciones, estectáculos..."/>
				<xs:enumeration value="Tiendas y pequeño comercio"/>
				<xs:enumeration value="Habitaciones de hoteles, hostales..."/>
				<xs:enumeration value="Otros"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="Address">
		<xs:simpleType>
			<xs:restriction base="xs:string">
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="AdjacentSurfaceId">
		<xs:complexType>
			<xs:attribute name="surfaceIdRef" use="required">
				<xs:simpleType>
					<xs:restriction base="xs:string">
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
		</xs:complexType>
	</xs:element>
	<xs:element name="AdjacentWindowId">
		<xs:complexType>
			<xs:attribute name="windowIdRef" use="required">
				<xs:simpleType>
					<xs:restriction base="xs:string">
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
		</xs:complexType>
	</xs:element>
	<xs:element name="AgeOfHeatPump">
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="Posterior a 2013"/>
				<xs:enumeration value="Entre 1994 y 2013"/>
				<xs:enumeration value="Anterior a 1994"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="AirCavityType">
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="No ventilada"/>
				<xs:enumeration value="Ligeramente ventilada"/>
				<xs:enumeration value="Ventilada"/>
				<xs:enumeration value="Rellena de Aislamiento"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="Airflow">
		<xs:simpleType>
			<xs:restriction base="xs:decimal">
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="AirflowResistance" type="xs:decimal"/>
	<xs:element name="AirLoop">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="AirLoopEquipment"/>
			</xs:sequence>
			<xs:attribute name="id" type="xs:ID" use="required"/>
		</xs:complexType>
	</xs:element>	
	<xs:element name="AirLoopEquipment">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="Zone"/>
				<xs:element ref="TypeOfFan"/>
				<xs:element ref="Service"/>
				<xs:element ref="Consumption"/>
				<xs:sequence minOccurs="0">
					<xs:element ref="NumberOfHoursWithDemand" minOccurs="0"/>
					<xs:element ref="WorksWhenNoDemand" minOccurs="0"/>
					<xs:sequence minOccurs="0">
						<xs:element ref="HeatingSeasonDuration" minOccurs="0"/>
						<xs:element ref="CoolingSeasonDuration" minOccurs="0"/>
						<xs:element ref="FractionPowerWhenNoDemand" minOccurs="0"/>
					</xs:sequence>
				</xs:sequence>
			</xs:sequence>
			<xs:attribute name="calculationType" use="required">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Conocido (Ensayado/justificado)"/>
						<xs:enumeration value="Estimado"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
			<xs:attribute name="id" type="xs:ID" use="required"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="AirPrimaryEquipment">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="Zone"/>
				<xs:element ref="Name"/>
				<xs:element ref="Airflow"/>
				<xs:element ref="HasHeatRecoveryUnit"/>
				<xs:element ref="SeasonalPerformance"/>
			</xs:sequence>
			<xs:attribute name="equipmentType" type="xs:string" use="required"/>
			<xs:attribute name="id" type="xs:ID" use="required"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="Area">
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="ST_Area">
					<xs:attribute name="unit" use="required">
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="SquareMeters"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:attribute>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="AwningFabric">
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="Tejido opaco"/>
				<xs:enumeration value="Tejido translúcido"/>
			</xs:restriction>	
		</xs:simpleType>
	</xs:element>
	<xs:element name="AwningTilt">
		<xs:simpleType>
			<xs:restriction base="xsd:double">
				<xs:minInclusive value="0"/>
				<xs:maxInclusive value="180"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="AwningType">
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="Caso A"/>
				<xs:enumeration value="Caso B"/>
			</xs:restriction>	
		</xs:simpleType>
	</xs:element>
	<xs:element name="Blind"> 
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="OverhangDepth"/>
				<xs:element ref="OverhangHeight"/>
				<xs:element ref="BlindTilt"/>
				<xs:element ref="BlindAzimuth"/>
				<xs:element ref="BlindTransmittance"/>
				<xs:element ref="BlindReflectance"/>
				<xs:element ref="AwningType"/>
				<xs:element ref="AwningTilt"/>
				<xs:element ref="AwningFabric"/>
				<xs:element ref="SkylightWidth"/>
				<xs:element ref="SkylightLength"/>
				<xs:element ref="SkylightDepth"/>
			</xs:sequence>
			<xs:attribute name="calculationType" use="required">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="DA1Table12Overhang"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
			<xs:attribute name="id" type="xs:ID" use="required"/>
		</xs:complexType>
	</xs:element>
	<xs:element name="BlindAzimuth">
		<xs:simpleType>
			<xs:restriction base="xs:double">
				<xs:minInclusive value="0"/>
				<xs:maxInclusive value="360"/>				
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="BlindReflectance">
		<xs:simpleType>
			<xs:restriction base="xs:decimal">
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="BlindTilt">
		<xs:simpleType>
			<xs:restriction base="xsd:double">
				<xs:minInclusive value="0"/>
				<xs:maxInclusive value="180"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="BlindTransmittance">
		<xs:simpleType>
			<xs:restriction base="xs:decimal">
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="BoilerInsulationLevel">
		<xs:complexType>
			<xs:attribute name="unit" use="required">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="SquareM"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
		</xs:complexType>
	</xs:element>
	<xs:element name="CE3X">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="CustomerData"/>
				<xs:element ref="Opening" maxOccurs="unbounded"/>
				<xs:element ref="Blind" maxOccurs="unbounded"/>
				<xs:element ref="ThermalBridge" maxOccurs="unbounded"/>
				<xs:element ref="ShadowPattern" maxOccurs="unbounded"/>
				<xs:element ref="HydronicLoop" maxOccurs="unbounded"/>
				<xs:element ref="EnergyContribution" maxOccurs="unbounded"/>
				<xs:element ref="LightingSystem" maxOccurs="unbounded"/>
				<xs:element ref="AirPrimaryEquipment" maxOccurs="unbounded"/>
				<xs:element ref="FanEquipment" maxOccurs="unbounded"/>
				<xs:element ref="PumpEquipment" maxOccurs="unbounded"/>	
				<xs:element ref="CoolingTowerEquipment" maxOccurs="unbounded"/>
				<xs:element ref="Construction" maxOccurs="unbounded"/>
				<xs:element ref="Material" maxOccurs="unbounded"/>
			</xs:sequence>
			<xs:attribute name="order" use="required">
				<xs:simpleType>
					<xs:restriction base="xs:byte">
						<xs:enumeration value="0"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
		</xs:complexType>
	</xs:element>
	<xs:element name="City">
		<xs:simpleType>
			<xs:restriction base="xs:string">
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="CombustionEfficiency">
		<xs:complexType>
			<xs:attribute name="units" use="required">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="Percent"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
		</xs:complexType>
	</xs:element>
	<xs:element name="CombustionLoadFactor" type="xs:decimal"/>
	<xs:element name="Construction">
		<xs:complexType>
			<xs:choice>
				<xs:sequence>
					<xs:element ref="ConstructionType" type="xs:string"/>
					<xs:element ref="WallComposition" type="xs:string"/>
					<xs:sequence minOccurs="0">
						<xs:choice>
							<xs:sequence>
								<xs:element ref="SlabType"/>
								<xs:element ref="AirCavityType"/>
								<xs:element ref="InsulationIsPresent"/>
							</xs:sequence>
							<xs:sequence>
								<xs:element ref="AirCavityType"/>
								<xs:element ref="InsulationIsPresent"/>
								<xs:element ref="InsulationPosition"/>
							</xs:sequence>
						</xs:choice>
						<xs:element ref="InsulationType"/>
						<xs:element ref="Thickness"/>
						<xs:element ref="R-value"/>
					</xs:sequence>
				</xs:sequence>
				<xs:sequence>
					<xs:element ref="SlabDepth"/>
					<xs:element ref="Perimeter"/>
					<xs:element ref="InsulationIsPresent"/>
					<xs:element ref="InsulationLocation"/>
					<xs:element ref="HowDefineInsulationResistance"/>
					<xs:element ref="Thickness"/>
					<xs:element ref="R-value"/>
				</xs:sequence>
				<xs:element ref="NonHabitableSpaceType"/>
				<xs:element ref="Mass"/>
			</xs:choice>
			<xs:attribute name="calculationType">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="CerramientoConocido"/>
						<xs:enumeration value="CubiertaExteriorEstimada"/>
						<xs:enumeration value="FachadaExteriorEstimada"/>
						<xs:enumeration value="ParticionInteriorHorizontalConNHInferiorConocida"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
			<xs:attribute name="id" type="xs:ID" use="required"/>
			<xs:attribute name="caculationType">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="CubiertaExteriorDefecto"/>
						<xs:enumeration value="SueloConTerrenoEstimado"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:attribute>
		</xs:complexType>
	</xs:element>
	<xs:element name="ConstructionType">
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="Cubierta"/> 
				<xs:enumeration value="Cubierta plana"/>
				<xs:enumeration value="Cubierta plana ventilada"/>
				<xs:enumeration value="Cubierta ajardinada"/>
				<xs:enumeration value="Cubierta inclinada"/>
				<xs:enumeration value="Cubierta inclinada ventildad"/>
				<xs:enumeration value="Doble hoja con cámara"/>
				<xs:enumeration value="Una hoja"/>
				<xs:enumeration value="Facahada ventilada"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="Consumption">
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="ST_Consumption">
					<xs:attribute name="unit" use="required">
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="kilowatt-hour"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:attribute>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="ComsumptionCurveDefinition">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="CurveCoefficient1"/>
				<xs:element ref="CurveCoefficient2"/>
				<xs:element ref="CurveCoefficient3"/>
				<xs:element ref="CurveCoefficient4"/>
			</xs:sequence>
		</xs:complexType>							
	</xs:element>													
	<xs:element name="CoolingCoverage">
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="ST_CoolingCoverage">
					<xs:attribute name="unit" use="required">
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="SquareM"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:attribute>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="CoolingDemandCoveragePercentage">
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="ST_CoolingDemandCoveragePercentage">
					<xs:attribute name="unit" use="required">
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="percentage"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:attribute>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>	
	<xs:element name="CoolingSeasonDuration">
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="ST_CoolingSeasonDuration">
					<xs:attribute name="unit" use="optional">
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="hours"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:attribute>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="CurveCoefficient1">
		<xs:simpleType>
			<xs:restriction base="xs:decimal">
				<xs:minInclusive value="0"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="CurveCoefficient2">
		<xs:simpleType>
			<xs:restriction base="xs:decimal">
				<xs:minInclusive value="0"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="CurveCoefficient3">
		<xs:simpleType>
			<xs:restriction base="xs:decimal">
				<xs:minInclusive value="0"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="CurveCoefficient4">
		<xs:simpleType>
			<xs:restriction base="xs:decimal">
				<xs:minInclusive value="0"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="CustomerData">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="Name"/>
				<xs:element ref="Address"/>
				<xs:element name="State" type="StateType"/>
				<xs:element ref="City"/>
				<xs:element ref="ZipcodeOrPostalCode"/>
				<xs:element ref="PhoneNumber"/>
				<xs:element ref="e-mail"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:element name="DHWCoverage">
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="ST_DHWCoverage">
					<xs:attribute name="unit" use="required">
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="SquareM"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:attribute>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="DHWDemandCoveragePercentage">
		<xs:complexType>
			<xs:simpleContent>
				<xs:extension base="ST_DHWDemandCoveragePercentage">
					<xs:attribute name="unit" use="required">
						<xs:simpleType>
							<xs:restriction base="xs:string">
								<xs:enumeration value="percentage"/>
							</xs:restriction>
						</xs:simpleType>
					</xs:attribute>
				</xs:extension>
			</xs:simpleContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="DHWTankPresent">
		<xs:simpleType>
			<xs:restriction base="xs:string">
				<xs:enumeration value="False"/>
				<xs:enumeration value="True"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="DHWUA">  
		<xs:simpleType>
			<xs:restriction base="xs:string">
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="DifussionResistanceFactor" type="xs:decimal"/>
	<xs:element name="DynamicStiffness" type="xs:decimal"/>
	<xs:element name="ElasticMaterial" type="xs:decimal"/>
	<xs:element name="Elevacion1">
		<xs:simpleType>
			<xs:restriction base="xs:decimal">
				<xs:minInclusive value="0"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="Elevacion2">
		<xs:simpleType>
			<xs:restriction base="xs:decimal">
				<xs:minInclusive value="0"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="Elevacion3">
		<xs:simpleType>
			<xs:restriction base="xs:decimal">
				<xs:minInclusive value="0"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="Elevacion4">
		<xs:simpleType>
			<xs:restriction base="xs:decimal">
				<xs:minInclusive value="0"/>
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="EnergyConsumed">
		<xs:simpleType>
			<xs:restriction base="xs:decimal">
			</xs:restriction>
		</xs:simpleType>
	</xs:element>
	<xs:element name="EnergyContribution">
		<xs:complexType>
			<xs:sequence>
				<xs:element ref="Zone"/>
				<xs:element ref="Name"/>
				<xs:element ref="RenewableEnergySourcesArePresent"/>
				<xs:sequence minOccurs="0">
					<xs:element ref="DHWDemandCoveragePercentage"/>
					<xs:element ref="HeatingDemandCoveragePercentage"/>
					<xs:element ref="CoolingDemandCoveragePercentage"/>
				</xs:sequence>
				<xs:element name="RenewableElectricityOrCHPIsPresent"/>
				<xs:sequence minOccurs="0">
					<xs:element ref="SelfConsumedElectricityGeneratedEnergy"/>
					<xs:element ref="RecoveredHeatForDomesticHotWater"/>
					<xs:element ref="RecoveredHeatForHeating"/>
					<xs:element ref="RecoveredCoolingEnergy"/>
					<xs:element ref="EnergyConsumed"/>
					<xs:element ref="FuelType"/>
					<xs:element ref="NominalPower"/>
				</xs:sequence>
